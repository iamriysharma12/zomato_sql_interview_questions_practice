--ques.1) write an sql query to find the top 5 most-ordered dishes from a given resturant.

```sql
-- Table: orders
-- Columns: orderid,dishname,resturant,quantity, orderdate
```

--solution 01.) -----MYSQL,POSTGRESQL
select dishname,sum(quantity) as total_orders
from orders
where resturant ="R101"
group by dishname
order by total_orders desc
limit 5;

------SQL SERVER
select top 5 dishname,sum(quantity) as total_orders
from orders
where resturant ="R101"
group by dishname
order by total orders DESC;

------ORACLE
SELECT DISHNAME,SUM(QUANTITY) AS TOTAL_ORDERS
FROM ORDERS
WHERE RESTURANT='R101'
GROUP BY DISHNAME
ORDER BY TOTAL_ORDERS DESC
FETCH FIRST 5 ROWS ONLY;  

